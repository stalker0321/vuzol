VUZOL_ENVIRONMENT=development
VUZOL_SERVICE_NAME=vuzol
VUZOL_LOG_LEVEL=INFO
VUZOL_HOST=127.0.0.1
VUZOL_PORT=8000
VUZOL_WORKER_POLL_INTERVAL_SECONDS=1.0
# VUZOL_REGISTRY_FILE=/app/config/registries.toml
# VUZOL_DATABASE_DSN_REFERENCE=env:VUZOL_DATABASE_DSN
# VUZOL_TELEGRAM_BOT_TOKEN_REFERENCE=env:VUZOL_TELEGRAM_BOT_TOKEN
# VUZOL_TELEGRAM_BOT_TOKEN=replace-with-one-bot-token
# VUZOL_ALLOWED_USER_IDS=[123456789]
# VUZOL_ALLOWED_CHAT_IDS=[-1001234567890]
# VUZOL_REGISTRY_FILE_HOST=./config/registries.toml
# VUZOL_TELEGRAM__DELIVERY_POLL_INTERVAL_SECONDS=1.0
# VUZOL_TELEGRAM__DELIVERY_LEASE_SECONDS=30
# VUZOL_TELEGRAM__DELIVERY_MAX_ATTEMPTS=5
# VUZOL_TELEGRAM__DELIVERY_RETRY_MIN_SECONDS=1.0
# VUZOL_TELEGRAM__DELIVERY_RETRY_MAX_SECONDS=60.0
# VUZOL_INTERPRETATION__PROFILE_ID=cheap-interpreter
# VUZOL_OPENAI_INTERPRETER_API_KEY=replace-with-provider-api-key
# VUZOL_OPENAI_TRANSCRIPTION_API_KEY=replace-with-provider-api-key
# VUZOL_OPENAI_EXECUTOR_API_KEY=replace-with-separate-provider-api-key
# VUZOL_INTERPRETATION__FALLBACK_PROFILE_IDS=[fallback-interpreter]
# VUZOL_INTERPRETATION__TRANSCRIPTION_PROFILE_ID=voice-transcriber
# VUZOL_INTERPRETATION__POLL_INTERVAL_SECONDS=1.0
# VUZOL_INTERPRETATION__LEASE_SECONDS=300
# VUZOL_INTERPRETATION__MAX_ATTEMPTS=3
# VUZOL_INTERPRETATION__AUTOMATIC_EXECUTION_ENABLED=false
# VUZOL_INTERPRETATION__EVALUATION_REPORT_FILE=/app/config/evaluation-report.json
# VUZOL_RUNTIME_ENV_FILE=/home/user/.config/vuzol/runtime.env
# After setting the token, IDs, and registry: docker compose --profile telegram up
# After configuring interpreter/transcription profiles: docker compose --profile interpretation up
# VUZOL_REPOSITORY_ROOT=/srv/vuzol/repositories
# VUZOL_ARTIFACT_ROOT=/srv/vuzol/artifacts
# VUZOL_SECRET_FILE_ROOT=/run/secrets
# VUZOL_DATABASE__POOL_SIZE=5
# VUZOL_DATABASE__MAX_OVERFLOW=5
# VUZOL_DATABASE__POOL_TIMEOUT_SECONDS=30
# VUZOL_DATABASE__STATEMENT_TIMEOUT_MS=30000
# VUZOL_DATABASE__LOCK_TIMEOUT_MS=5000
# VUZOL_POSTGRES_PASSWORD=vuzol-local-only
# VUZOL_DATABASE_DSN=postgresql+psycopg://vuzol:vuzol-local-only@127.0.0.1:5432/vuzol # pragma: allowlist secret
