# syntax=docker/dockerfile:1.7
FROM ghcr.io/astral-sh/uv:0.11.28@sha256:5c3ab83183a73c5d319a77009eb425b60d5bb937f339fb7876788ebf567baf48 AS uv

FROM python:3.12.11-slim-bookworm@sha256:c00fc7b44d844b6da22861ec24af43968a5200eac4ec607b4725d585165d6b49

COPY --from=uv /uv /usr/local/bin/uv

RUN apt-get update \
    && apt-get install --yes --no-install-recommends acl git make postgresql-15 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY pyproject.toml uv.lock ./
COPY deploy/validation/verify_dependency_audit.py /usr/local/bin/vuzol-offline-dependency-audit
COPY deploy/validation/run_tests.py /usr/local/bin/vuzol-offline-test

ENV UV_PROJECT_ENVIRONMENT=/opt/vuzol-validation \
    UV_LINK_MODE=copy \
    UV_NO_SYNC=1 \
    UV_OFFLINE=1 \
    PATH=/opt/vuzol-validation/bin:/usr/local/bin:/usr/bin:/bin

RUN UV_NO_SYNC=0 UV_OFFLINE=0 uv sync \
        --frozen \
        --no-cache \
        --no-install-project \
        --all-groups \
    && mkdir -p /opt/vuzol-validation-audit \
    && sha256sum pyproject.toml uv.lock > /opt/vuzol-validation-audit/inputs.sha256 \
    && /opt/vuzol-validation/bin/pip-audit \
        --format json \
        --output /opt/vuzol-validation-audit/pip-audit.json \
    && chmod 0555 /usr/local/bin/vuzol-offline-dependency-audit \
    && chmod 0555 /usr/local/bin/vuzol-offline-test \
    && find /opt/vuzol-validation -type d -name __pycache__ -prune -exec rm -rf {} + \
    && chmod -R a-w /opt/vuzol-validation /opt/vuzol-validation-audit \
    && rm -rf /build /root/.cache

RUN install -d -o postgres -g postgres -m 0700 /opt/vuzol-postgres-template \
    && su -s /bin/sh postgres -c \
        "/usr/lib/postgresql/15/bin/initdb --pgdata=/opt/vuzol-postgres-template --auth=trust --no-locale --encoding=UTF8" \
    && chown -R 10001:10001 /opt/vuzol-postgres-template \
    && chmod -R a-w /opt/vuzol-postgres-template

RUN /usr/sbin/groupadd --system --gid 10001 sandbox \
    && /usr/sbin/useradd --system --uid 10001 --gid sandbox --no-create-home sandbox \
    && mkdir -p /workspace \
    && chown 10001:10001 /workspace

USER 10001:10001
WORKDIR /workspace

ENTRYPOINT []
CMD ["python", "--version"]
