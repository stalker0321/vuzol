VUZOL_ENVIRONMENT=production
VUZOL_SERVICE_NAME=vuzol
VUZOL_LOG_LEVEL=INFO
VUZOL_REGISTRY_FILE=/etc/vuzol/executor-registries.toml
VUZOL_DATABASE_DSN_REFERENCE=env:VUZOL_DATABASE_DSN
# pragma: allowlist nextline secret
VUZOL_DATABASE_DSN=postgresql+psycopg://vuzol:vuzol-local-only@127.0.0.1:5432/vuzol
VUZOL_REPOSITORY_ROOT=/srv/vuzol/repositories
VUZOL_WORKTREE_ROOT=/srv/vuzol/worktrees
VUZOL_ARTIFACT_ROOT=/srv/vuzol/artifacts
VUZOL_EXECUTION__ENABLED=true
VUZOL_EXECUTION__ROOTLESS_DOCKER_SOCKET=/run/user/994/docker.sock
VUZOL_EXECUTION__REQUIRE_PREFLIGHT=true
VUZOL_EXECUTION__PROXY_IMAGE=vuzol-connect-proxy@sha256:3adc8035f5273f9fcdf07a55fa58c7212fb356394cb9861bc77db5e8eef8dc92
VUZOL_EXECUTION__PROXY_RUNTIME_ROOT=/run/user/994/vuzol/proxy
VUZOL_EXECUTION__SANDBOX_SECCOMP_PROFILE=/etc/vuzol/sandbox-seccomp.json
VUZOL_EXECUTION__SANDBOX_SECCOMP_PROFILE_SHA256=bdbf16ca9391fc73e7f7f75d910dce7718c81009fb205fb04529021adaec4efa
