VUZOL_ENVIRONMENT=production
VUZOL_SERVICE_NAME=vuzol
VUZOL_LOG_LEVEL=INFO
VUZOL_REGISTRY_FILE=/etc/vuzol/executor-registries.toml
VUZOL_REGISTRY_OVERLAY_FILE=/var/lib/vuzol/registry/projects.json
VUZOL_PROJECT_TEMPLATE_ID=vuzol
VUZOL_DATABASE_DSN_REFERENCE=env:VUZOL_DATABASE_DSN
VUZOL_DATABASE_DSN=postgresql+asyncpg://vuzol:replace-me@localhost/vuzol  # pragma: allowlist secret
VUZOL_REPOSITORY_ROOT=/srv/vuzol/repositories
VUZOL_WORKTREE_ROOT=/srv/vuzol/worktrees
VUZOL_ARTIFACT_ROOT=/srv/vuzol/artifacts
VUZOL_ALLOWED_USER_IDS=[123456789]
VUZOL_ALLOWED_CHAT_IDS=[-1001234567890]
VUZOL_TELEGRAM_BOT_TOKEN_REFERENCE=env:VUZOL_TELEGRAM_BOT_TOKEN
VUZOL_TELEGRAM_BOT_TOKEN=replace-me  # pragma: allowlist secret
